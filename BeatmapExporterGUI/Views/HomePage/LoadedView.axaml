<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:BeatmapExporterGUI.ViewModels.HomePage"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="1024"
             x:Class="BeatmapExporterGUI.Views.HomePage.LoadedView"
             x:DataType="vm:LoadedViewModel">

  <StackPanel Spacing="18"
              Margin="6">

    <TextBlock FontSize="24"
               HorizontalAlignment="Center"
               Text="{Binding Loc[Home.Loaded]}" />
    
    <Separator />
    
    <TextBlock FontSize="18"
               Text="{Binding Loc[Home.BeatmapTotals]}" />
    <TextBlock Text="{Binding TotalBeatmapSets}" />
    <TextBlock Text="{Binding TotalBeatmapDiffs}" />
    <TextBlock Text="{Binding TotalCollections}" />
  
    <Separator />

    <TextBlock FontSize="18"
               Text="{Binding Loc[Home.SelectedForExport]}" />
    <TextBlock Text="{Binding SelectedSets}" />
    <TextBlock Text="{Binding SelectedDiffs}" />
    <TextBlock Text="{Binding FiltersInfo}" />
    <TextBlock Text="{Binding ExportModeInfo}" />
    
    <Separator />
    
  </StackPanel>
  
</UserControl>
