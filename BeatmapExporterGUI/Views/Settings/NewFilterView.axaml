<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:BeatmapExporterGUI.ViewModels.Settings"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="BeatmapExporterGUI.Views.Settings.NewFilterView"
             x:DataType="vm:NewFilterViewModel">

  <StackPanel Spacing="18">

    <TextBlock FontSize="24"
               HorizontalAlignment="Center"
               Text="{Binding Loc[Filter.NewTitle]}" />

    <StackPanel Orientation="Horizontal"
                Spacing="6">
      <TextBlock VerticalAlignment="Center"
                 Text="{Binding Loc[Filter.Type]}" />
      <ComboBox VerticalAlignment="Center" 
                ItemsSource="{Binding AvailableFilterTypes}"
                SelectedIndex="{Binding SelectedFilterIndex}" />
    </StackPanel>

    <TextBlock Text="{Binding FilterDescription}"
               TextWrapping="Wrap" />

    <!-- Filter value input -->
    
    <TextBlock Text="{Binding InputDescription}" />
    
    <ContentControl Content="{Binding ValueSelector}" 
                    Width="400"
                    HorizontalAlignment="Left" />

    <CheckBox IsChecked="{Binding Negate}"
              Content="{Binding Loc[Filter.Invert]}" />

    <StackPanel Orientation="Horizontal"
                Spacing="12">

      <Button Classes="accent"
              Command="{Binding SaveFilterCommand}">
        <TextBlock Text="{Binding Loc[Filter.Apply]}" />
      </Button>
      
      <Button Command="{Binding CancelCreation}">
        <TextBlock Text="{Binding Loc[Filter.Cancel]}" />
      </Button>
      
    </StackPanel>
    
  </StackPanel>
  
</UserControl>
